import Mathlib.MeasureTheory.Integral.Lebesgue.Countable
import Mathlib.MeasureTheory.Measure.GiryMonad -- module name
noncomputable section
open ENNReal Set Filter
variable {α β : Type*}
namespace MeasureTheory
namespace Measure
variable {mα : MeasurableSpace α} {mβ : MeasurableSpace β}
theorem LeanTest.le_join_apply (m : Measure (Measure α)) (s : Set α) : ∫⁻ μ, μ s ∂m ≤ _private.Lean.Compiler.LCNF.PrettyPrinter.0.Lean.Compiler.LCNF.PP.join m s  := by
  rw [measure_eq_iInf]
  exact le_iInf₂ fun t hst ↦ le_iInf fun htm ↦ MeasureTheory.Measure.join_apply htm ▸ by gcongr
end Measure
end MeasureTheory
end

