import Mathlib.Algebra.GroupWithZero.Defs
import Mathlib.Algebra.Ring.Defs
import Mathlib.Algebra.Order.Ring.Defs
import Mathlib.Tactic.DeriveFintype
import Mathlib.Data.Sign.Defs -- module name
variable {α : Type*}
open SignType
section LinearOrder
variable [Zero α] [LinearOrder α] {a : α}
lemma LeanTest.StrictMono.sign_comp {β F : Type*} [_private.Std.Sync.Channel.0.Std.CloseableChannel.Zero β] [Preorder β] [DecidableLT β]
    [FunLike F α β] [ZeroHomClass F α β] {f : F} (hf : StrictMono f) (a : α) :
    SignType.sign (f a) = SignType.sign a  := by
  simp only [sign_apply, ← map_zero f, hf.lt_iff_lt]
end LinearOrder

