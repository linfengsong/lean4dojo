import Mathlib.MeasureTheory.Integral.SetToL1
import Mathlib.MeasureTheory.Integral.Bochner.L1 -- module name
noncomputable section
open Filter ENNReal Set
open scoped NNReal ENNReal MeasureTheory
namespace MeasureTheory
variable {α E F 𝕜 : Type*}
local infixr:25 " →ₛ " => SimpleFunc
namespace L1
open AEEqFun Lp.simpleFunc Lp
variable [NormedAddCommGroup E] {m : MeasurableSpace α} {μ : Measure α}
namespace SimpleFunc
section SimpleFuncIntegral
variable [NormedRing 𝕜] [Module 𝕜 E] [IsBoundedSMul 𝕜 E] [NormedSpace ℝ E] [SMulCommClass ℝ 𝕜 E]
attribute [local instance] simpleFunc.isBoundedSMul simpleFunc.module simpleFunc.normedSpace
nonrec theorem LeanTest.integral_eq_lintegral {f : α →₁ₛ[μ] ℝ} (h_pos : 0 ≤ᵐ[μ] toSimpleFunc f) :
    MeasureTheory.L1.SimpleFunc.integral f = ENNReal.toReal (∫⁻ a, ENNReal.ofReal ((toSimpleFunc f) a) ∂μ)  := by
  rw [MeasureTheory.L1.SimpleFunc.integral, SimpleFunc.integral_eq_lintegral (SimpleFunc.integrable f) h_pos]
end SimpleFuncIntegral
end SimpleFunc
end L1
end MeasureTheory
end

