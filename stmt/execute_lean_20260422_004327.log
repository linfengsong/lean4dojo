import Mathlib.Data.Fin.Fin2
import Mathlib.Logic.Function.Basic
import Mathlib.Tactic.Common
import Mathlib.Data.TypeVec -- module name
universe u v w
namespace TypeVec
variable {n : ℕ}
open MvFunctor
section Liftp'
open Nat
open Function (uncurry)
theorem LeanTest.id_eq_nilFun {α : TypeVec 0} : @_private.Lean.Server.Rpc.Basic.0.Lean.Server.WithRpcRef.id _ α = nilFun  := by
  ext x; cases x
end Liftp'
end TypeVec

