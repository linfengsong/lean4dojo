import Mathlib.Data.Fin.Fin2
import Mathlib.Logic.Function.Basic
import Mathlib.Tactic.Common
import Mathlib.Data.TypeVec -- module name
universe u v w
namespace TypeVec
variable {n : ℕ}
open MvFunctor
section Liftp'
open Nat
open Function (uncurry)
theorem LeanTest.prod_id : ∀ {n} {α β : TypeVec.{u} n}, (_private.Lean.Server.Rpc.Basic.0.Lean.Server.WithRpcRef.id ⊗' _private.Lean.Server.Rpc.Basic.0.Lean.Server.WithRpcRef.id) = (_private.Lean.Server.Rpc.Basic.0.Lean.Server.WithRpcRef.id : α ⊗ β ⟹ _)  := by
  intros
  ext i a
  induction i with
  | fz => cases a; rfl
  | fs _ i_ih => apply i_ih
end Liftp'
end TypeVec

