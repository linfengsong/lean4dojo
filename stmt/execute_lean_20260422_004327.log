import Init.WF
import Init.WFTactics
import Init.Data.Nat.Basic
import Init.MetaTypes
import Init.Data.Nat.Div.Basic -- module name
public section
@[expose] section
namespace Nat
theorem LeanTest.div_eq (x y : Nat) : x / y = if 0 < y ∧ y ≤ x then (x - y) / y + 1 else 0  := by
  change Nat.div _ _ = ite _ (Nat.div _ _ + 1) _
  unfold Nat.div
  split
  next =>
    rw [Nat.div.go]
    split
    next =>
      simp only [and_self, ↓reduceIte, *]
      congr 1
      apply div.go.fuel_congr
    next =>
      simp only [and_false, ↓reduceIte, *]
  next =>
    simp only [false_and, ↓reduceIte, *]
end Nat
end
end

