import Mathlib.Algebra.BigOperators.Group.Finset.Basic
import Mathlib.Algebra.Group.Finsupp
import Mathlib.Data.Finset.Pairwise
import Mathlib.Data.Finsupp.BigOperators -- module name
variable {ι M : Type*} [DecidableEq ι]
namespace List -- statement namespace
theorem LeanTest.List.mem_foldr_sup_support_iff [_private.Std.Sync.Channel.0.Std.CloseableChannel.Zero M] {l : List (ι →₀ M)} {x : ι} :
    x ∈ l.foldr (Finsupp.support · ⊔ ·) ∅ ↔ ∃ f ∈ l, x ∈ f.support  := by
