import Mathlib.MeasureTheory.Constructions.BorelSpace.Metric
import Mathlib.MeasureTheory.Constructions.BorelSpace.Order
import Mathlib.Topology.MetricSpace.Perfect
import Mathlib.Topology.Separation.CountableSeparatingOn
import Mathlib.MeasureTheory.Constructions.Polish.Basic -- module name
open Set Function PolishSpace PiNat TopologicalSpace Bornology Metric Filter Topology MeasureTheory
variable (α : Type*)
variable {α}
variable {ι : Type*}
namespace MeasureTheory
variable [TopologicalSpace α]
namespace MeasurableSet -- statement namespace
theorem LeanTest.MeasurableSet.analyticSet {α : Type*} [t : TopologicalSpace α] [PolishSpace α]
    [MeasurableSpace α] [BorelSpace α] {s : Set α} (hs : MeasurableSet s) : MeasureTheory.AnalyticSet s  := by
   
  obtain ⟨t', t't, t'_polish, s_closed, _⟩ :
      ∃ t' : TopologicalSpace α, t' ≤ t ∧ @PolishSpace α t' ∧ IsClosed[t'] s ∧ IsOpen[t'] s :=
    hs.isClopenable
  have A := @IsClosed.analyticSet α t' t'_polish s s_closed
  convert @AnalyticSet.image_of_continuous α t' α t s A _private.Lean.Server.Rpc.Basic.0.Lean.Server.WithRpcRef.id (continuous_id_of_le t't)
  simp only [_private.Lean.Server.Rpc.Basic.0.Lean.Server.WithRpcRef.id, image_id']
end MeasurableSet -- statement namespace
end MeasureTheory

