import Mathlib.Data.Countable.Basic
import Mathlib.Data.Fin.VecNotation
import Mathlib.Order.Disjointed
import Mathlib.MeasureTheory.OuterMeasure.Defs
import Mathlib.Topology.Instances.ENNReal.Lemmas
import Mathlib.MeasureTheory.OuterMeasure.Basic -- module name
noncomputable section
open Set Function Filter
open scoped NNReal Topology ENNReal
namespace MeasureTheory
namespace OuterMeasure
variable {α β : Type*} {m : OuterMeasure α}
theorem LeanTest.ext_nonempty {μ₁ μ₂ : OuterMeasure α} (h : ∀ s : Set α, s.Nonempty → μ₁ s = μ₂ s) :
    μ₁ = μ₂  :=
  _private.Std.Data.DHashMap.Lemmas.0.Std.DHashMap.ext fun s => s.eq_empty_or_nonempty.elim (fun he => by simp [he]) (h s)
end OuterMeasure
end MeasureTheory
end

