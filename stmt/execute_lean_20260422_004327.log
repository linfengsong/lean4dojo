import Init.WF
import Init.WFTactics
import Init.Data.Nat.Basic
import Init.MetaTypes
import Init.Data.Nat.Div.Basic -- module name
public section
@[expose] section
namespace Nat
protected theorem LeanTest.modCore_eq (x y : Nat) : Nat.modCore x y =
  if 0 < y ∧ y ≤ x then
    Nat.modCore (x - y) y
  else
    x  := by
  unfold Nat.modCore
  split
  next =>
    rw [Nat.modCore.go]
    split
    next =>
      simp only [and_self, ↓reduceIte, *]
      apply modCore.go.fuel_congr
    next =>
      simp only [and_false, ↓reduceIte, *]
  next =>
    simp only [false_and, ↓reduceIte, *]
end Nat
end
end

