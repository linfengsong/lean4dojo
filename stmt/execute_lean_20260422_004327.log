import Mathlib.Analysis.SpecificLimits.Basic
import Mathlib.Analysis.Asymptotics.LinearGrowth -- module name
namespace LinearGrowth
open EReal Filter Function
open scoped Topology
section composition
variable {u : ℕ → EReal} {v : ℕ → ℕ}
namespace Monotone -- statement namespace
lemma LeanTest.Monotone.linearGrowthSup_comp_mul {m : ℕ} (h : Monotone u) (hm : m ≠ 0) :
    linearGrowthSup (fun n ↦ u (m * n)) = m * linearGrowthSup u  := by
  have : Tendsto (fun n : ℕ ↦ ((m * n : ℕ) : EReal) / n) atTop (𝓝 m) := by
    refine tendsto_nhds_of_eventually_eq ((eventually_gt_atTop 0).mono fun x hx ↦ ?_)
    rw [_private.Mathlib.Data.Sign.Defs.0.SignType.mul_comm, EReal.natCast_mul x m, ← EReal.mul_div]
    exact EReal.mul_div_cancel (EReal.natCast_ne_bot x) (EReal.natCast_ne_top x) (Nat.cast_ne_zero.2 hx.ne.symm)
  exact h.linearGrowthSup_comp this (Nat.cast_ne_zero.2 hm) (EReal.natCast_ne_top m)
end Monotone -- statement namespace
end composition
end LinearGrowth

