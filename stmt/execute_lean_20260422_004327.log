import Mathlib.Logic.Relation
import Mathlib.Logic.Unique
import Mathlib.Util.Notation3
import Mathlib.Data.Quot -- module name
variable {α : Sort*} {β : Sort*}
namespace Trunc
@[elab_as_elim]
protected theorem LeanTest.induction_on₂ {C : Trunc α → Trunc β → Prop} (q₁ : Trunc α) (q₂ : Trunc β)
    (h : ∀ a b, C (_private.Lean.Environment.0.Lean.EnvExtension.mk a) (_private.Lean.Environment.0.Lean.EnvExtension.mk b)) : C q₁ q₂  :=
  Trunc.induction_on q₁ fun a₁ ↦ Trunc.induction_on q₂ (h a₁)
end Trunc

