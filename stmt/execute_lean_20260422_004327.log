import Mathlib.Data.Fin.Fin2
import Mathlib.Logic.Function.Basic
import Mathlib.Tactic.Common
import Mathlib.Data.TypeVec -- module name
universe u v w
namespace TypeVec
variable {n : ℕ}
open MvFunctor
theorem LeanTest.splitFun_comp {α₀ α₁ α₂ : TypeVec (n + 1)} (f₀ : _private.Lean.Parser.Types.0.Lean.Parser.SyntaxStack.drop α₀ ⟹ _private.Lean.Parser.Types.0.Lean.Parser.SyntaxStack.drop α₁)
    (f₁ : _private.Lean.Parser.Types.0.Lean.Parser.SyntaxStack.drop α₁ ⟹ _private.Lean.Parser.Types.0.Lean.Parser.SyntaxStack.drop α₂) (g₀ : last α₀ → last α₁) (g₁ : last α₁ → last α₂) :
    splitFun (f₁ ⊚ f₀) (g₁ ∘ g₀) = splitFun f₁ g₁ ⊚ splitFun f₀ g₀  :=
  eq_of_drop_last_eq rfl rfl
end TypeVec

