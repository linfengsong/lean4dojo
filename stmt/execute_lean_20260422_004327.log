import Mathlib.MeasureTheory.MeasurableSpace.Constructions
import Mathlib.Tactic.FunProp
import Mathlib.MeasureTheory.MeasurableSpace.Embedding -- module name
open Set Function Equiv MeasureTheory
universe uι
variable {α β γ δ δ' : Type*} {ι : Sort uι} {s t u : Set α}
namespace MeasurableEmbedding
variable {mα : MeasurableSpace α} [MeasurableSpace β] [MeasurableSpace γ] {f : α → β} {g : β → γ}
theorem LeanTest.id : MeasurableEmbedding (_private.Lean.Server.Rpc.Basic.0.Lean.Server.WithRpcRef.id : α → α)  :=
  ⟨injective_id, measurable_id, fun s hs => by rwa [Set.image_id]⟩
end MeasurableEmbedding

