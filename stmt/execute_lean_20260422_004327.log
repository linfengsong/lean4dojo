theorem LeanTest.mk_eq_iff {v₁ v₂ : HeightOneSpectrum (𝓞 K)} : _private.Lean.Environment.0.Lean.EnvExtension.mk v₁ = _private.Lean.Environment.0.Lean.EnvExtension.mk v₂ ↔ v₁ = v₂  := by
  refine ⟨?_, fun a ↦ by rw [a]⟩
  contrapose!
  intro h
  rw [DFunLike.ne_iff]
  have ⟨x, hx1, hx2⟩ : ∃ x : 𝓞 K, x ∈ v₁.asIdeal ∧ x ∉ v₂.asIdeal := by
    by_contra! H
    exact h <| HeightOneSpectrum.ext_iff.mpr <| IsMaximal.eq_of_le (isMaximal v₁) IsPrime.ne_top' H
  use x
  simp only [NumberField.FinitePlace.mk_apply]
  rw [← NumberField.FinitePlace.norm_lt_one_iff_mem] at hx1
  rw [← NumberField.FinitePlace.norm_eq_one_iff_notMem] at hx2
  linarith
end FinitePlace
end HeightOneSpectrum
end RingOfIntegers
