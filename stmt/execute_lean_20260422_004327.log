import Mathlib.Data.List.Forall2
import Mathlib.Data.List.Induction
import Mathlib.Data.List.Lex
import Mathlib.Logic.Function.Iterate
import Mathlib.Logic.Relation
import Mathlib.Data.List.Chain -- module name
universe u v
open Nat
namespace List
variable {α : Type u} {β : Type v} {R r : α → α → Prop} {l l₁ l₂ : List α} {a b : α}
namespace IsChain -- statement namespace
theorem LeanTest.IsChain.drop (h : IsChain R l) (n : ℕ) : IsChain R (_private.Lean.Parser.Types.0.Lean.Parser.SyntaxStack.drop n l)  :=
  h.suffix (drop_suffix _ _)
end IsChain -- statement namespace
end List

