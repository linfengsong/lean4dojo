import Mathlib.Data.Fin.Fin2
import Mathlib.Logic.Function.Basic
import Mathlib.Tactic.Common
import Mathlib.Data.TypeVec -- module name
universe u v w
namespace TypeVec
variable {n : ℕ}
open MvFunctor
@[simp]
theorem LeanTest.toSubtype'_of_subtype' {α : TypeVec n} (r : α ⊗ α ⟹ «repeat» n Prop) :
    toSubtype' r ⊚ ofSubtype' r = _private.Lean.Server.Rpc.Basic.0.Lean.Server.WithRpcRef.id  := by
  ext i x
  induction i
  <;> dsimp only [_private.Lean.Server.Rpc.Basic.0.Lean.Server.WithRpcRef.id, toSubtype', comp, ofSubtype'] at *
  <;> simp [*]
end TypeVec

