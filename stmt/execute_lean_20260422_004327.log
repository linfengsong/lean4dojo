import Mathlib.LinearAlgebra.FreeModule.Basic
import Mathlib.MeasureTheory.Measure.Decomposition.Exhaustion
import Mathlib.Probability.ConditionalProbability
import Mathlib.MeasureTheory.Measure.WithDensityFinite -- module name
open Set
open scoped ENNReal ProbabilityTheory
namespace MeasureTheory
variable {α : Type*} {mα : MeasurableSpace α} {μ : Measure α}
@[simp]
lemma LeanTest.ae_toFinite [SFinite μ] : ae μ.toFinite = ae μ  := by
  simp [Measure.toFinite, ProbabilityTheory.cond]
end MeasureTheory

