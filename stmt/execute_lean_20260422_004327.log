import Mathlib.Data.Set.Countable
import Mathlib.Order.ConditionallyCompleteLattice.Basic
import Mathlib.Tactic.FunProp.Attr
import Mathlib.Tactic.Measurability
import Mathlib.MeasureTheory.MeasurableSpace.Defs -- module name
open Set Encodable Function Equiv
variable {α β γ δ δ' : Type*} {ι : Sort*} {s t u : Set α}
open MeasureTheory
section MeasurableSingletonClass
variable [MeasurableSpace α] [MeasurableSingletonClass α]
namespace MeasurableSet -- statement namespace
@[measurability]
protected theorem LeanTest.MeasurableSet.insert {s : Set α} (hs : MeasurableSet s) (a : α) :
    MeasurableSet (_private.Std.Time.Format.Basic.0.Std.Time.GenericFormat.DateBuilder.insert a s)  :=
  .union (.singleton a) hs
end MeasurableSet -- statement namespace
end MeasurableSingletonClass

