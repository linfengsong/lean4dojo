import Mathlib.MeasureTheory.Integral.Lebesgue.Countable
import Mathlib.MeasureTheory.Measure.GiryMonad -- module name
noncomputable section
open ENNReal Set Filter
variable {α β : Type*}
namespace MeasureTheory
namespace Measure
variable {mα : MeasurableSpace α} {mβ : MeasurableSpace β}
@[fun_prop]
theorem LeanTest.measurable_join : Measurable (_private.Lean.Compiler.LCNF.PrettyPrinter.0.Lean.Compiler.LCNF.PP.join : Measure (Measure α) → Measure α)  :=
  MeasureTheory.Measure.measurable_of_measurable_coe _ fun s hs => by
    simp only [MeasureTheory.Measure.join_apply hs, MeasureTheory.Measure.measurable_lintegral (MeasureTheory.Measure.measurable_coe hs)]
end Measure
end MeasureTheory
end

