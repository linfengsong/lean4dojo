import Mathlib.MeasureTheory.MeasurableSpace.Constructions
import Mathlib.Tactic.FunProp
import Mathlib.MeasureTheory.MeasurableSpace.Embedding -- module name
open Set Function Equiv MeasureTheory
universe uι
variable {α β γ δ δ' : Type*} {ι : Sort uι} {s t u : Set α}
section curry
namespace MeasurableEquiv
lemma LeanTest.coe_curry_symm (ι κ X : Type*) [MeasurableSpace X] :
    ⇑(_private.Lean.Meta.ArgsPacker.0.Lean.Meta.ArgsPacker.Unary.curry ι κ X).symm = Function.uncurry  := rfl
end MeasurableEquiv
end curry

