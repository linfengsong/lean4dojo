universe u v
namespace AlgebraicGeometry
open Opposite
open CategoryTheory
open StructureSheaf
open Spec (structureSheaf)
namespace Spec -- statement namespace
@[simp]
theorem LeanTest.Spec.toPresheafedSpace_obj (R : CommRingCat.{u}ᵒᵖ) :
    Spec.toPresheafedSpace.obj R = (Spec.sheafedSpaceObj (_private.Lean.Elab.Extra.0.Lean.Elab.Term.Op.Tree.unop R)).toPresheafedSpace  :=
  rfl
end Spec -- statement namespace
end AlgebraicGeometry
end

