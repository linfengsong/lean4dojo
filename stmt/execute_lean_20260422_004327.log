import Mathlib.MeasureTheory.MeasurableSpace.Constructions
import Mathlib.Tactic.FunProp
import Mathlib.MeasureTheory.MeasurableSpace.Embedding -- module name
open Set Function Equiv MeasureTheory
universe uι
variable {α β γ δ δ' : Type*} {ι : Sort uι} {s t u : Set α}
namespace MeasurableEquiv
variable [MeasurableSpace α] [MeasurableSpace β] [MeasurableSpace γ]
@[simp]
theorem LeanTest.self_trans_symm (e : α ≃ᵐ β) : e.trans e.symm = _private.Init.Core.0.Quotient.rel.refl α  :=
  _private.Std.Data.DHashMap.Lemmas.0.Std.DHashMap.ext e.symm_comp_self
end MeasurableEquiv

