import Mathlib.Data.Fin.Fin2
import Mathlib.Logic.Function.Basic
import Mathlib.Tactic.Common
import Mathlib.Data.TypeVec -- module name
universe u v w
namespace TypeVec
variable {n : ℕ}
open MvFunctor
theorem LeanTest.appendFun_comp_splitFun {α γ : TypeVec n} {β δ : Type*} {ε : TypeVec (n + 1)}
    (f₀ : _private.Lean.Parser.Types.0.Lean.Parser.SyntaxStack.drop ε ⟹ α) (f₁ : α ⟹ γ) (g₀ : last ε → β) (g₁ : β → δ) :
    appendFun f₁ g₁ ⊚ splitFun f₀ g₀ = splitFun (α' := γ.append1 δ) (f₁ ⊚ f₀) (g₁ ∘ g₀)  :=
  (splitFun_comp _ _ _ _).symm
end TypeVec

