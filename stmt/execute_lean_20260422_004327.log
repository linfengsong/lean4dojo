    (@_private.Lean.Server.Rpc.Basic.0.Lean.Server.WithRpcRef.id _ α ::: g₁ ∘ g₀) = (_private.Lean.Server.Rpc.Basic.0.Lean.Server.WithRpcRef.id ::: g₁) ⊚ (_private.Lean.Server.Rpc.Basic.0.Lean.Server.WithRpcRef.id ::: g₀)  :=
  eq_of_drop_last_eq rfl rfl
end TypeVec

