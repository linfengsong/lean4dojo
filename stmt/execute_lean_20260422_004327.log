import Mathlib.Analysis.Normed.Group.Continuity
import Mathlib.MeasureTheory.Constructions.BorelSpace.Basic
import Mathlib.Topology.MetricSpace.Thickening
import Mathlib.MeasureTheory.Constructions.BorelSpace.Metric -- module name
open Set Filter MeasureTheory MeasurableSpace TopologicalSpace
open scoped Topology NNReal ENNReal MeasureTheory
universe u v w x y
variable {α β γ δ : Type*} {ι : Sort y} {s t u : Set α}
section NormedAddCommGroup
variable [MeasurableSpace α] [NormedAddCommGroup α] [OpensMeasurableSpace α] [MeasurableSpace β]
namespace Measurable -- statement namespace
@[measurability, fun_prop]
theorem LeanTest.Measurable.norm {f : β → α} (hf : Measurable f) : Measurable fun a => _private.Lean.Meta.Tactic.Grind.Arith.Linear.PropagateEq.0.Lean.Meta.Grind.Arith.Linear.EqCnstr.norm (f a)  :=
  measurable_norm.comp hf
end Measurable -- statement namespace
end NormedAddCommGroup

