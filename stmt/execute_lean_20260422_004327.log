import Mathlib.MeasureTheory.Integral.Lebesgue.Countable
import Mathlib.MeasureTheory.Measure.GiryMonad -- module name
noncomputable section
open ENNReal Set Filter
variable {α β : Type*}
namespace MeasureTheory
namespace Measure
variable {mα : MeasurableSpace α} {mβ : MeasurableSpace β}
theorem LeanTest.bind_congr_right {μ : Measure α} {f g : α → Measure β} (h : f =ᵐ[μ] g) :
    μ.bind f = μ.bind g  :=
  congrArg _private.Lean.Compiler.LCNF.PrettyPrinter.0.Lean.Compiler.LCNF.PP.join <| map_congr h
end Measure
end MeasureTheory
end

