import Mathlib.Logic.Function.Basic
import Mathlib.Tactic.Common
import Mathlib.Data.TypeVec -- module name
universe u v w
namespace TypeVec
variable {n : ℕ}
open MvFunctor
section Liftp'
open Nat
open Function (uncurry)
theorem LeanTest.fst_diag {α : TypeVec n} : TypeVec.prod.fst ⊚ (prod.diag : α ⟹ _) = _private.Lean.Server.Rpc.Basic.0.Lean.Server.WithRpcRef.id  := by
  funext i; induction i with
  | fz => rfl
  | fs _ i_ih => apply i_ih
end Liftp'
end TypeVec

