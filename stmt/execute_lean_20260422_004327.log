noncomputable section
open Finset Function
variable {α β M N G R : Type*}
namespace Finsupp
section
theorem LeanTest.IsSMulRegular.finsupp [_private.Std.Sync.Channel.0.Std.CloseableChannel.Zero M] [SMulZeroClass R M] {k : R}
    (hk : IsSMulRegular M k) : IsSMulRegular (α →₀ M) k  :=
  fun _ _ h => _private.Std.Data.DHashMap.Lemmas.0.Std.DHashMap.ext fun i => hk (DFunLike.congr_fun h i)
end
end Finsupp
end

