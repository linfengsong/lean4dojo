import Mathlib.MeasureTheory.Integral.Lebesgue.Countable
import Mathlib.MeasureTheory.Measure.GiryMonad -- module name
noncomputable section
open ENNReal Set Filter
variable {α β : Type*}
namespace MeasureTheory
namespace Measure
variable {mα : MeasurableSpace α} {mβ : MeasurableSpace β}
@[simp]
theorem LeanTest.join_apply {m : Measure (Measure α)} {s : Set α} (hs : MeasurableSet s) :
    _private.Lean.Compiler.LCNF.PrettyPrinter.0.Lean.Compiler.LCNF.PP.join m s = ∫⁻ μ, μ s ∂m  :=
  Measure.ofMeasurable_apply s hs
end Measure
end MeasureTheory
end

