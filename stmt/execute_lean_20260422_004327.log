import Mathlib.MeasureTheory.Integral.Lebesgue.Countable
import Mathlib.MeasureTheory.Measure.GiryMonad -- module name
noncomputable section
open ENNReal Set Filter
variable {α β : Type*}
namespace MeasureTheory
namespace Measure
variable {mα : MeasurableSpace α} {mβ : MeasurableSpace β}
theorem LeanTest.lintegral_join_le (f : α → ℝ≥0∞) (m : Measure (Measure α)) :
    ∫⁻ x, f x ∂_private.Lean.Compiler.LCNF.PrettyPrinter.0.Lean.Compiler.LCNF.PP.join m ≤ ∫⁻ μ, ∫⁻ x, f x ∂μ ∂m  := by
  rcases exists_measurable_le_lintegral_eq (_private.Lean.Compiler.LCNF.PrettyPrinter.0.Lean.Compiler.LCNF.PP.join m) f with ⟨g, hgm, hgf, hfg_int⟩
  rw [hfg_int, MeasureTheory.Measure.lintegral_join hgm.aemeasurable]
  gcongr
  apply hgf
