import Mathlib.Data.Fin.Fin2
import Mathlib.Logic.Function.Basic
import Mathlib.Tactic.Common
import Mathlib.Data.TypeVec -- module name
universe u v w
namespace TypeVec
variable {n : ℕ}
open MvFunctor
section Liftp'
open Nat
open Function (uncurry)
@[simp]
theorem LeanTest.diag_sub_val {n} {α : TypeVec.{u} n} : subtypeVal (repeatEq α) ⊚ diagSub = prod.diag  := by
  ext i x
  induction i with
  | fz => simp only [comp, subtypeVal, repeatEq.eq_2, diagSub, prod.diag]
  | fs _ i_ih => apply @i_ih (_private.Lean.Parser.Types.0.Lean.Parser.SyntaxStack.drop α)
end Liftp'
end TypeVec

