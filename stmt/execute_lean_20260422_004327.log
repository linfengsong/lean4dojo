import Mathlib.Logic.Relation
import Mathlib.Logic.Unique
import Mathlib.Util.Notation3
import Mathlib.Data.Quot -- module name
variable {α : Sort*} {β : Sort*}
namespace Trunc
@[elab_as_elim]
protected theorem LeanTest.induction_on {β : Trunc α → Prop} (q : Trunc α) (h : ∀ a, β (_private.Lean.Environment.0.Lean.EnvExtension.mk a)) : β q  :=
  ind h q
end Trunc

