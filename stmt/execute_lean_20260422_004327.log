import Mathlib.Logic.Encodable.Lattice
import Mathlib.MeasureTheory.MeasurableSpace.Defs
import Mathlib.Order.Disjointed
import Mathlib.MeasureTheory.PiSystem -- module name
open MeasurableSpace Set
open MeasureTheory
variable {α β : Type*}
namespace IsPiSystem -- statement namespace
theorem LeanTest.IsPiSystem.insert_univ {S : Set (Set α)} (h_pi : IsPiSystem S) :
    IsPiSystem (_private.Std.Time.Format.Basic.0.Std.Time.GenericFormat.DateBuilder.insert Set.univ S)  := by
  intro s hs t ht hst
  rcases hs with hs | hs
  · rcases ht with ht | ht <;> simp [hs, ht]
  · rcases ht with ht | ht
    · simp [hs, ht]
    · exact Set.mem_insert_of_mem _ (h_pi s hs t ht hst)
end IsPiSystem -- statement namespace

