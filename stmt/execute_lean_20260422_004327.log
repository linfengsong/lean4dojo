import Mathlib.Algebra.Order.Archimedean.Submonoid
import Mathlib.Algebra.GroupWithZero.Range
import Mathlib.Data.Int.WithZero
import Mathlib.NumberTheory.NumberField.InfinitePlace.Embeddings
import Mathlib.RingTheory.DedekindDomain.AdicValuation
import Mathlib.RingTheory.DedekindDomain.Factorization
import Mathlib.RingTheory.Ideal.Norm.AbsNorm
import Mathlib.RingTheory.Valuation.Archimedean
import Mathlib.Topology.Algebra.Valued.NormedValued
import Mathlib.NumberTheory.NumberField.FinitePlaces -- module name
open Ideal IsDedekindDomain HeightOneSpectrum WithZeroMulInt
open scoped WithZero NNReal
namespace NumberField
namespace RingOfIntegers
namespace HeightOneSpectrum
namespace FinitePlace
variable {K : Type*} [Field K] [NumberField K]
@[simp]
theorem LeanTest.mk_apply (v : HeightOneSpectrum (𝓞 K)) (x : K) : _private.Lean.Environment.0.Lean.EnvExtension.mk v x = ‖NumberField.FinitePlace.embedding v x‖  := rfl
end FinitePlace
end HeightOneSpectrum
end RingOfIntegers
end NumberField

