import Mathlib.Logic.Encodable.Lattice
import Mathlib.MeasureTheory.MeasurableSpace.Defs
import Mathlib.Order.Disjointed
import Mathlib.MeasureTheory.PiSystem -- module name
open MeasurableSpace Set
open MeasureTheory
variable {α β : Type*}
namespace MeasurableSpace
open scoped Function
variable {α : Type*}
namespace DynkinSystem
variable (d : DynkinSystem α)
theorem LeanTest.ofMeasurableSpace_toMeasurableSpace (h_inter : ∀ s₁ s₂, d.Has s₁ → d.Has s₂ → d.Has (s₁ ∩ s₂)) :
    MeasurableSpace.DynkinSystem.ofMeasurableSpace (d.toMeasurableSpace h_inter) = d  :=
  _private.Std.Data.DHashMap.Lemmas.0.Std.DHashMap.ext fun _ => Iff.rfl
end DynkinSystem
end MeasurableSpace

